{
  "name": "blog-platform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:blog\" \"npm run dev:flarebase\" \"npm run dev:auth-plugin\" --kill-others --names \"blog,flarebase,auth-plugin\" --prefix-colors \"blue,green,yellow\"",
    "dev:blog": "next dev -p 3002",
    "dev:flarebase": "cd ../.. && cargo run -p flare-server",
    "dev:auth-plugin": "node auth-plugin-service.js",
    "dev:minimal": "concurrently \"npm run dev:blog\" \"npm run dev:flarebase\" --kill-others --names \"blog,flarebase\" --prefix-colors \"blue,green\"",
    "build": "next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "test:e2e": "node tests/e2e/run_e2e_tests.js",
    "test:e2e:blog": "node tests/e2e/run_e2e_tests.js",
    "test:registration": "node tests/e2e/registration-standalone.test.js",
    "test:auth": "node tests/e2e/auth-plugin-integration.test.js"
  },
  "dependencies": {
    "@flarebase/client": "file:../../clients/js",
    "@flarebase/react": "file:../../clients/react",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "socket.io-client": "^4.8.3",
    "swr": "^2.3.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.5.9",
    "puppeteer": "^24.40.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
